{
  "name": "ngx-rive",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/ngx-rive/src",
  "prefix": "ngx",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/ngx-rive"],
      "options": {
        "command": "ng-packagr -p packages/ngx-rive/ng-package.json -c packages/ngx-rive/tsconfig.lib.prod.json"
      },
      "configurations": {
        "development": {
          "command": "ng-packagr -p packages/ngx-rive/ng-package.json -c packages/ngx-rive/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/packages/ngx-rive"],
      "options": {
        "jestConfig": "packages/ngx-rive/jest.config.ts"
      }
    }
  }
}
